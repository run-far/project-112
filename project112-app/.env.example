# Supabase publishable values are safe in a browser build, but environment files stay untracked.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Private app by default. New registrations are hidden in the frontend.
VITE_ALLOW_SIGNUP=false

# Strava OAuth is handled securely by the Supabase Edge Function.
# No Strava secret belongs in the frontend.
